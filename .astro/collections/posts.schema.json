{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "heroImage": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "enum": [
        "dog-food",
        "dog-treats",
        "dog-health",
        "dog-gear",
        "dog-training",
        "dog-toys",
        "cat-supplies",
        "guides",
        "comparisons"
      ]
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featured": {
      "default": false,
      "type": "boolean"
    },
    "affiliate": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate",
    "category"
  ]
}