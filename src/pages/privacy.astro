---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy - FetchPicks" description="FetchPicks privacy policy explains how we collect, use, and protect your information.">
  <article style="max-width: 720px; margin: 0 auto;">
    <h1 class="page-title">Privacy Policy</h1>
    <p style="color: var(--text-muted); margin-bottom: 32px;">Last updated: May 2026</p>

    <section style="margin-top: 24px;">
      <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 8px;">Information We Collect</h2>
      <p style="color: var(--text-secondary); line-height: 1.8; margin-bottom: 16px;">
        We collect minimal information. When you visit FetchPicks, we may collect:
      </p>
      <ul style="color: var(--text-secondary); line-height: 1.8; padding-left: 20px;">
        <li>Basic analytics data (pages visited, time on site, referral source) via privacy-focused analytics.</li>
        <li>Information you voluntarily provide via contact forms or email.</li>
      </ul>
    </section>

    <section style="margin-top: 24px;">
      <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 8px;">Cookies</h2>
      <p style="color: var(--text-secondary); line-height: 1.8; margin-bottom: 16px;">
        We use minimal cookies for site functionality. We do not use intrusive tracking cookies.
        Amazon affiliate links use cookies to track referrals for commission purposes.
        These cookies are set by Amazon, not by us.
      </p>
    </section>

    <section style="margin-top: 24px;">
      <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 8px;">Third-Party Services</h2>
      <p style="color: var(--text-secondary); line-height: 1.8; margin-bottom: 16px;">
        FetchPicks uses:
      </p>
      <ul style="color: var(--text-secondary); line-height: 1.8; padding-left: 20px;">
        <li><strong>Cloudflare</strong> - for CDN and security (privacy-focused).</li>
        <li><strong>Amazon Associates</strong> - for affiliate program cookie tracking.</li>
      </ul>
    </section>

    <section style="margin-top: 24px;">
      <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 8px;">Your Rights</h2>
      <p style="color: var(--text-secondary); line-height: 1.8; margin-bottom: 16px;">
        You have the right to request access to, correction of, or deletion of any personal data we hold.
        Contact us at <strong>hello@fetchpicks.com</strong> for any privacy-related requests.
      </p>
    </section>

    <section style="margin-top: 24px;">
      <h2 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 8px;">Contact</h2>
      <p style="color: var(--text-secondary); line-height: 1.8;">
        For privacy inquiries: <strong>hello@fetchpicks.com</strong>
      </p>
    </section>
  </article>
</BaseLayout>
